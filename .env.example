# Flask
APP_HOST=0.0.0.0
APP_PORT=5001
FLASK_DEBUG=false
CORS_ORIGINS=*

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=data

# ESP32 serial connection
SERIAL_ENABLED=true
SERIAL_PORT=/dev/cu.wchusbserial54E20196661
SERIAL_BAUDRATE=115200
SERIAL_TIMEOUT=2

# Face recognition
FACE_RECOGNITION_ENABLED=true
CAMERA_SOURCE=0
FACE_CASCADE_PATH=web/assets/face_detect.xml
FACE_MODEL_PATH=web/backend/models/my.yml

# Third-party API
EXCHANGE_RATE_BASE_URL=https://open.er-api.com/v6/latest
